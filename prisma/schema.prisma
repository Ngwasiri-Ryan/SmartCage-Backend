generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TelemetryReading {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  temperature  Float
  ammonia      Float
  feedWeight   Float    @default(0.0)
  fanActive    Boolean  @default(false)
  heaterActive Boolean  @default(false)

  @@index([createdAt])
}

model FeedReading {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  slot      FeedSlot
  weightKg  Float
  date      DateTime

  @@unique([slot, date])
  @@index([date])
}

model DailyFeedSummary {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique
  totalKg        Float
  isDeclineTrend Boolean  @default(false)

  @@index([date])
}

model Alert {
  id          Int           @id @default(autoincrement())
  createdAt   DateTime      @default(now())
  type        AlertType
  severity    AlertSeverity
  description String
  resolved    Boolean       @default(false)

  @@index([createdAt])
}

model DailyAISummary {
  id      Int      @id @default(autoincrement())
  date    DateTime @unique
  summary String
}

enum FeedSlot {
  MORNING
  AFTERNOON
  NIGHT
}

enum AlertType {
  TEMPERATURE
  AMMONIA
  FEED
  COMBINED
}

enum AlertSeverity {
  CAUTION
  WARNING
  CRITICAL
  EMERGENCY
}

model Camera {
  id           Int           @id @default(autoincrement())
  name         String
  rtspUrl      String
  zone         String
  active       Boolean       @default(true)
  healthAlerts HealthAlert[]
  accessLogs   AccessLog[]
}

model Personnel {
  id         Int         @id @default(autoincrement())
  name       String
  role       String
  active     Boolean     @default(true)
  faces      FaceData[]
  accessLogs AccessLog[]
}

model FaceData {
  id          Int       @id @default(autoincrement())
  personnelId Int
  personnel   Personnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
  angle       String    // "FRONT", "LEFT", "RIGHT"
  imagePath   String
  embedding   Float[]
}

model HealthAlert {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  cameraId      Int
  camera        Camera   @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  movementScore Float
  description   String
  snapshotPath  String?

  @@index([createdAt])
}

model AccessLog {
  id           Int        @id @default(autoincrement())
  createdAt    DateTime   @default(now())
  personnelId  Int?
  personnel    Personnel? @relation(fields: [personnelId], references: [id], onDelete: SetNull)
  cameraId     Int
  camera       Camera     @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  isAuthorized Boolean
  matchedName  String
  snapshotPath String?

  @@index([createdAt])
}
