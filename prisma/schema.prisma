generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TelemetryReading {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  temperature  Float
  ammonia      Float
  feedWeight   Float    @default(0.0)
  fanActive    Boolean  @default(false)
  heaterActive Boolean  @default(false)

  @@index([createdAt])
}

model FeedReading {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  slot      FeedSlot
  weightKg  Float
  date      DateTime

  @@unique([slot, date])
  @@index([date])
}

model DailyFeedSummary {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique
  totalKg        Float
  isDeclineTrend Boolean  @default(false)

  @@index([date])
}

model Alert {
  id          Int           @id @default(autoincrement())
  createdAt   DateTime      @default(now())
  type        AlertType
  severity    AlertSeverity
  description String
  resolved    Boolean       @default(false)

  @@index([createdAt])
}

model DailyAISummary {
  id      Int      @id @default(autoincrement())
  date    DateTime @unique
  summary String
}

enum FeedSlot {
  MORNING
  AFTERNOON
  NIGHT
}

enum AlertType {
  TEMPERATURE
  AMMONIA
  FEED
  COMBINED
}

enum AlertSeverity {
  CAUTION
  WARNING
  CRITICAL
  EMERGENCY
}
